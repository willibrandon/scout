<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>14.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <MSBuildTreatWarningsAsErrors>true</MSBuildTreatWarningsAsErrors>
    <AnalysisLevel>10.0</AnalysisLevel>
    <AnalysisMode>AllEnabledByDefault</AnalysisMode>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <Deterministic>true</Deterministic>
    <InvariantGlobalization>true</InvariantGlobalization>
    <InvariantTimezone>true</InvariantTimezone>
    <IsAotCompatible>true</IsAotCompatible>
    <TrimMode>full</TrimMode>
    <ILLinkTreatWarningsAsErrors>true</ILLinkTreatWarningsAsErrors>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>
    <SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
    <_TrimmerShowRedundantSuppressions>true</_TrimmerShowRedundantSuppressions>
    <RootNamespace>Scout</RootNamespace>
    <IsPackable>false</IsPackable>
    <VersionPrefix>0.4.4</VersionPrefix>
    <Version>$(VersionPrefix)</Version>
    <AssemblyVersion>0.4.4.0</AssemblyVersion>
    <FileVersion>0.4.4.0</FileVersion>
    <ScoutRipgrepVersion>15.1.0</ScoutRipgrepVersion>
    <ScoutRipgrepRevision>4857d6fa67db69a95cd4b6f2adda5d807d4d0119</ScoutRipgrepRevision>
    <ScoutRipgrepRevisionShort>4857d6fa67</ScoutRipgrepRevisionShort>
    <AssemblyInformationalVersion>$(VersionPrefix)+ripgrep.$(ScoutRipgrepVersion).$(ScoutRipgrepRevisionShort)</AssemblyInformationalVersion>
    <Product>Scout</Product>
    <Company>willibrandon</Company>
    <Authors>willibrandon</Authors>
    <Description>Scout - byte-oriented regex and ripgrep-compatible search libraries for .NET Native AOT</Description>
    <RepositoryUrl>https://github.com/willibrandon/scout</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>
    <PackageId>$(MSBuildProjectName)</PackageId>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>regex;search;ripgrep;glob;gitignore;nativeaot;aot;bytes</PackageTags>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.SourceGen'">
    <TargetFramework>netstandard2.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <IsAotCompatible>false</IsAotCompatible>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'BenchmarkDotNet.Autogenerated'">
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup Condition="'$(IsTestProject)' == 'true'">
    <IsAotCompatible>false</IsAotCompatible>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Benchmarks'">
    <IsAotCompatible>false</IsAotCompatible>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Fuzz'">
    <IsAotCompatible>false</IsAotCompatible>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.App'">
    <AssemblyName>scout</AssemblyName>
    <OutputType>Library</OutputType>
    <NativeLib>Static</NativeLib>
    <PublishAot>true</PublishAot>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Pcre2'">
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Ignore'">
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Os'">
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Scout.Cli'">
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup Condition="'$(MSBuildProjectName)' == 'Scout.App'">
    <DirectPInvoke Include="__Internal" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" PrivateAssets="all" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="all" />
    <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" PrivateAssets="all" />
  </ItemGroup>
</Project>
