<?xml version="1.0" encoding="UTF-8"?>
<!--
  Scout Windows Installer (WiX v5)

  IMPORTANT:
    - UpgradeCode MUST remain constant across all versions (CE243186-7E49-4E33-A17F-B2D6A37CFB39).
    - ProductCode is generated per build and MUST change each version.
    - Version is passed via -d Version=X.Y.Z during release builds.
    - SourceDir is passed via -d SourceDir=path\to\scout-win-<arch> package stage.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="scout"
           Version="$(var.Version).0"
           Manufacturer="willibrandon"
           UpgradeCode="CE243186-7E49-4E33-A17F-B2D6A37CFB39"
           Scope="perMachine">

    <SummaryInformation Description="Feature-complete port of ripgrep to .NET Native AOT" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of scout is already installed."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="scout">
        <Component Id="PathEnvComponent" Guid="B2C8E0B0-13C1-4B19-8D21-F264C9BC82BE">
          <RegistryValue Root="HKLM"
                         Key="Software\scout"
                         Name="PathConfigured"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
          <Environment Id="PATH"
                       Name="PATH"
                       Value="[INSTALLFOLDER]"
                       Permanent="no"
                       Part="last"
                       Action="set"
                       System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="scout" Level="1">
      <Files Directory="INSTALLFOLDER" Include="$(var.SourceDir)\**" />
      <ComponentRef Id="PathEnvComponent" />
    </Feature>

  </Package>
</Wix>
